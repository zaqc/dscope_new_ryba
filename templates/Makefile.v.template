VERILATOR=verilator
IVERILOG=iverilog
VVP=vvp

# Target executable
TARGET = {{tbName}}.vvp
VCD_FILE = {{tbName}}.vcd
WAVE_VCD = {{tbName}}.vcd
WAVE_CFG = {{tbName}}.gtkw

# Source files
SOURCES = {{files}} {{tbName}}.v

# Compiler flags
FLAGS = -Wall -Winfloop -g2005-sv -DTESTMODE=1 -DTARGET_NAME="\""$(TARGET)"\""

all: run

build:
	$(IVERILOG) $(FLAGS) -o $(TARGET) $(SOURCES)

run: build
	$(VVP) $(TARGET)

wave: run
	gtkwave --rcvar 'fontname_signals Monospace 11' $(WAVE_VCD) $(WAVE_CFG)

clean:
	rm -f $(TARGET) *.vcd
