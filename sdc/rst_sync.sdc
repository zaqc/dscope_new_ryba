# =========================================================================
# File: src/rst_sync.sdc
# Description: Design Constraints for Clock Domain Crossing (CDC) and Resets
#              Fully compliant with the 16-Channel UT Defectoscope specifications.
# Target: Intel Quartus Prime / TimeQuest Timing Analyzer
# =========================================================================

# -------------------------------------------------------------------------
# 1. PLL Clocks Derivation (Quartus Specific)
# -------------------------------------------------------------------------
# Automatically derive clocks generated by PLL (Quartus IP Core)
derive_pll_clocks -create_base_clocks
derive_clock_uncertainty

# Standalone Fallback: if the design is analyzed outside the top level (no PLL in netlist)
if { [get_collection_size [get_clocks -nowarn {*sys_clk*}]] == 0 } {
    post_message -type info "PLL clocks not found. Generating fallback clocks for standalone analysis..."
    create_clock -name sys_clk -period 12.500 [get_ports sys_clk]
    create_clock -name adc_clk -period 15.385 [get_ports adc_clk]
    create_clock -name log_clk -period 40.000 [get_ports log_clk]
    create_clock -name dac_clk -period 20.000 [get_ports dac_clk]
    create_clock -name hi_clk  -period  4.000 [get_ports hi_clk]
}

# -------------------------------------------------------------------------
# 2. Asynchronous Clock Groups (Clock Domain Crossing Isolation)
# -------------------------------------------------------------------------
# Cut timing paths between all mutually asynchronous clock domains.
# CDC is safely handled by 'cdc_pulse_sync' modules.
set_clock_groups -asynchronous \
    -group [get_clocks -nowarn {*sys_clk*}] \
    -group [get_clocks -nowarn {*adc_clk*}] \
    -group [get_clocks -nowarn {*log_clk*}] \
    -group [get_clocks -nowarn {*dac_clk*}] \
    -group [get_clocks -nowarn {*hi_clk*}]

# -------------------------------------------------------------------------
# 3. Asynchronous Input Port Reset Constraint
# -------------------------------------------------------------------------
# The master reset 'rst_n' is asynchronous. We cut its timing path to the 
# synchronization registers 'rst_gen'.
set_false_path -from [get_ports {rst_n}]

# -------------------------------------------------------------------------
# 4. Clock Domain Crossing (CDC) Pulse Synchronizer Constraints
# -------------------------------------------------------------------------
# For CDC toggle synchronization paths inside 'cdc_pulse_sync':
# From: src_toggle (source domain register)
# To:   dst_sync_reg[0] (first stage register in destination domain)

# Cut standard timing path checks (Setup/Hold) to prevent false violations
set_false_path -to [get_registers {*cdc_pulse_sync:*|dst_sync_reg[0]}]

# Bound the maximum physical routing delay between the toggle register 
# and the synchronizer to prevent long routing wires and improve MTBF.
# Max delay is constrained to 4.0 ns (period of the fastest hi_clk domain).
set_max_delay -to [get_registers {*cdc_pulse_sync:*|dst_sync_reg[0]}] 4.000

# -------------------------------------------------------------------------
# 5. Master Trigger input Constraints (i_sys_sync)
# -------------------------------------------------------------------------
# i_sys_sync is synchronous to sys_clk (80 MHz, period 12.5ns).
# Assuming a standard 3ns output delay from the driving source.
set_input_delay -clock [get_clocks {*sys_clk*}] -max 3.000 [get_ports {i_sys_sync}]
set_input_delay -clock [get_clocks {*sys_clk*}] -min 0.500 [get_ports {i_sys_sync}]